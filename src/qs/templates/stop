{% extends "base_template" %}
{% block content %}
if [ -e "${PIDFILE}" ] && (ps -u $(whoami) -opid= |
                           grep -P "^\s*$(cat ${PIDFILE})$" &> /dev/null); then
    /home/sholden/.local/bin/uwsgi --stop ${PIDFILE}
    rm $PIDFILE
else
    echo "No PID file"
    exit 99
fi
{% endblock %}