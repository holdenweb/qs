{% extends "base_template" %}
{% block content %}
if [ -e "${PIDFILE}" ] && (ps -u $(whoami) -opid= |
                           grep -P "^\s*$(cat ${PIDFILE})$" &> /dev/null); then
  echo "Already running."
  exit 99
fi
echo -n 'Started at '
date "+%Y-%m-%d %H:%M:%S"
${APPHOME}/.venv/bin/uwsgi --ini ${APPHOME}/uwsgi.ini
{% endblock %}